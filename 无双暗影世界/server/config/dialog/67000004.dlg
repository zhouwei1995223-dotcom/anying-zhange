<root>
	<taskEntries>
		<task id="10002003" doing="zhentu-doing" />
		<task id="10002004" doing="caicai-completed" />
		<task id="10002006" doing="xiwang-doing" />
		<task id="10002007" doing="xunyun-doing" />
		<task id="10002008" doing="shenmi-doing" />
		<task id="10002009" doing="mzsl-doing" />
		<task id="10002010" doing="txz-doing" />
		<task id="10002011" doing="smsr-doing" />
